        %tmp.333 = "Cannot predict now.";
        %tmp.334 = dup %tmp.332;
        %tmp.335 = aputv %tmp.334 13 %tmp.333;
        %tmp.336 = "Concentrate and\n ask again.";
        %tmp.337 = dup %tmp.335;
        %tmp.338 = aputv %tmp.337 14 %tmp.336;
