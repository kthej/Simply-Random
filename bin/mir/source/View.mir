        %tmp.293 = newa 20;
        %tmp.294 = "It is certain.";
        %tmp.295 = dup %tmp.293;
        %tmp.296 = aputv %tmp.295 0 %tmp.294;
        %tmp.297 = "It is decidedly so.";
        %tmp.298 = dup %tmp.296;
        %tmp.299 = aputv %tmp.298 1 %tmp.297;
        %tmp.300 = "Without a doubt.";
        %tmp.301 = dup %tmp.299;
        %tmp.302 = aputv %tmp.301 2 %tmp.300;
        %tmp.303 = "Yes definitely.";
        %tmp.304 = dup %tmp.302;
        %tmp.305 = aputv %tmp.304 3 %tmp.303;
        %tmp.306 = "You may rely on it.";
        %tmp.307 = dup %tmp.305;
        %tmp.308 = aputv %tmp.307 4 %tmp.306;
        %tmp.309 = "As I see it, yes.";
        %tmp.310 = dup %tmp.308;
        %tmp.311 = aputv %tmp.310 5 %tmp.309;
        %tmp.312 = "Most likely.";
        %tmp.313 = dup %tmp.311;
        %tmp.314 = aputv %tmp.313 6 %tmp.312;
        %tmp.315 = "Outlook good.";
        %tmp.316 = dup %tmp.314;
        %tmp.317 = aputv %tmp.316 7 %tmp.315;
        %tmp.318 = "Yes.";
        %tmp.319 = dup %tmp.317;
        %tmp.320 = aputv %tmp.319 8 %tmp.318;
        %tmp.321 = "Signs point to yes.";
        %tmp.322 = dup %tmp.320;
